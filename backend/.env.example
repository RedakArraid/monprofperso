# Mon Prof Perso — variables d'environnement du backend.
# Copier ce fichier en `.env` (non versionné) et y mettre les vraies valeurs.
#   cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=monprofperso
POSTGRES_PASSWORD=change-me            # ⚠️ en prod : secret fort, jamais commité
POSTGRES_DB=monprofperso

# --- Authentification ---
JWT_SECRET=change-me               # ⚠️ en prod : 32+ caractères aléatoires, secret

# --- Cloudflare (optionnel — DNS, admin R2, Workers via API) ---
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# --- Stockage objet (Cloudflare R2 ou MinIO local) ---
# Prod / cloud : R2 (console Cloudflare → R2 → Manage R2 API Tokens)
# S3_ENDPOINT=<account_id>.r2.cloudflarestorage.com
# S3_PORT=443
# S3_USE_SSL=true
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=monprofperso
#
# Dev hors-ligne : MinIO Docker (docker compose --profile local-minio up -d)
# S3_ENDPOINT=minio
# S3_PORT=9000
# S3_USE_SSL=false
# S3_ACCESS_KEY=monprofperso
# S3_SECRET_KEY=change-me-too
# S3_BUCKET=monprofperso

# --- Ports hôte (mapping docker) ---
API_PORT=8099
PG_HOST_PORT=5544
ADMINER_PORT=8098
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=8097
WEB_PORT=8095
