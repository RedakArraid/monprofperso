# Mon Prof Perso, STAGING (VPS). Copier vers .env.staging sur le serveur.
# Ne jamais committer .env.staging.

# --- Domaines Traefik ---
MP2_WEB_HOST=staging.monprofperso.com
MP2_API_HOST=staging-api.monprofperso.com

# --- PostgreSQL (base séparée de la prod) ---
POSTGRES_USER=monprofperso
POSTGRES_PASSWORD=GENERER_UN_SECRET_FORT
POSTGRES_DB=monprofperso_staging

# --- Authentification ---
JWT_SECRET=GENERER_32_OCTETS_ALEATOIRES

# --- Cloudflare R2 (bucket staging dédié recommandé) ---
S3_ENDPOINT=<account_id>.r2.cloudflarestorage.com
S3_PORT=443
S3_USE_SSL=true
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=monprofperso-staging
