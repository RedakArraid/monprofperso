# Mon Prof Perso — production (VPS). Copier vers .env.production sur le serveur.
# Ne jamais committer .env.production.

# --- Domaines Traefik ---
MP2_WEB_HOST=monprofperso.com
MP2_API_HOST=api.monprofperso.com

# --- PostgreSQL ---
POSTGRES_USER=monprofperso
POSTGRES_PASSWORD=GENERER_UN_SECRET_FORT
POSTGRES_DB=monprofperso

# --- Authentification ---
JWT_SECRET=GENERER_32_OCTETS_ALEATOIRES

# --- Cloudflare R2 (stockage fichiers) ---
S3_ENDPOINT=<account_id>.r2.cloudflarestorage.com
S3_PORT=443
S3_USE_SSL=true
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=monprofperso
